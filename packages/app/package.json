  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=6144 next dev",
    "dev:withchecks": "pnpm run checks && next dev",
    "build": "npx rimraf out && next build && pnpm run build:copyassets",
    "build:copyassets": "npx cpy public .next/standalone/packages/app/ && npx cpy .next/static .next/standalone/packages/app/.next/",
    "start": "next start",
    "start:prod": "node .next/standalone/packages/app/server.js",
    "checks": "pnpm run format:fix && pnpm run lint",
    "format": "prettier --check --ignore-path .gitignore ./src/",
    "format:fix": "prettier --write --ignore-path .gitignore ./src/",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings=0 || exit 0",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "test": "pnpm run build && pnpm run test:unit:ci",
    "test_TEMPORARY_DISABLED": "pnpm run build && pnpm run test:unit:ci && pnpm run test:e2e",
    "test:unit:ci": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "pnpm exec playwright test",
    "electron": "pnpm run build && electron .",
    "electron:start": "pnpm run build && electron-forge start",
    "electron:package": "pnpm run build && electron-forge package",
    "electron:make": "pnpm run build && electron-forge make"
  },
